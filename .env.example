# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com
# 1. Create a new project
# 2. Enable Google Identity API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add authorized origins:
#    - Local: http://localhost:5173
#    - Production: https://aurceive.github.io/20260328-gi-community-tier-list/
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here

# Google Form Configuration
# Get form ID from the URL: https://docs.google.com/forms/d/FORM_ID/viewform
# The FORM_ID is the long alphanumeric string in the URL
VITE_GOOGLE_FORM_ID=your_google_form_id_here
