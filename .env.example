# ============================================================================
# Google OAuth Configuration
# ============================================================================

# Google OAuth Client ID from Google Cloud Console
# https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable "Google Sign-In" API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add authorized JavaScript origins:
#    - Local: http://localhost:5173
#    - Production: https://aurceive.github.io
VITE_GOOGLE_OAUTH_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# ============================================================================
# Application Configuration
# ============================================================================

# Debug mode (shows console logs in browser)
VITE_DEBUG=false

# ============================================================================
# Notes
# ============================================================================
#
# Form submission does not require any additional environment variables.
# Character-to-entry-ID mapping is stored in public/form-character-mapping.json
# and loaded at runtime. To regenerate it:
#   npm run scripts:generate-form-mapping
#
