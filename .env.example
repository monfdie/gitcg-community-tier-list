# ============================================================================
# Google OAuth Configuration
# ============================================================================

# Google OAuth Client ID from Google Cloud Console
# https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable "Google+ API"
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add authorized origins:
#    - Local: http://localhost:5173
#    - Production: https://aurceive.github.io/20260328-gi-community-tier-list/
VITE_GOOGLE_OAUTH_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# ============================================================================
# Google Form Configuration
# ============================================================================

# Google Form ID from the form URL
# https://docs.google.com/forms/d/{FORM_ID}/viewform
VITE_GOOGLE_FORM_ID=1abc123def456ghi789jkl0

# Google Form Entry IDs (obtained from form inspection or pre-fill URLs)
# These map to the form fields in the same order as your form

# User information fields
VITE_FORM_ENTRY_NAME=entry.1234567890
VITE_FORM_ENTRY_EMAIL=entry.0987654321

# Tier assignment fields (each tier's characters as comma-separated list)
VITE_FORM_ENTRY_S_TIER=entry.1111111111
VITE_FORM_ENTRY_A_TIER=entry.2222222222
VITE_FORM_ENTRY_B_TIER=entry.3333333333
VITE_FORM_ENTRY_C_TIER=entry.4444444444
VITE_FORM_ENTRY_D_TIER=entry.5555555555

# Metadata fields
VITE_FORM_ENTRY_TIMESTAMP=entry.6666666666

# ============================================================================
# Application Configuration
# ============================================================================

# Debug mode (shows console logs)
VITE_DEBUG=false

# ============================================================================
# How to find Google Form Entry IDs
# ============================================================================
#
# Method 1: Browser DevTools
# 1. Open your Google Form in edit mode
# 2. Right-click on a form field → Inspect
# 3. Look for name="entry.XXXXXXXXXX" in the HTML
# 4. Copy the entry ID (just the numbers after "entry.")
#
# Method 2: Pre-fill URL
# 1. Open Google Form in edit mode
# 2. Click the three dots → "Get pre-filled link"
# 3. Fill in all fields as examples
# 4. Open the generated URL
# 5. Right-click → "Inspect" and search for "entry." in the HTML
#
