# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com
# 1. Create a new project
# 2. Enable Google Identity API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add authorized origins:
#    - Local: http://localhost:5173
#    - Production: https://aurceive.github.io/20260328-public-gi-tier-list/
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here

# Google Form Configuration
# Get form ID from the URL: https://docs.google.com/forms/d/FORM_ID/viewform
# The FORM_ID is the long alphanumeric string in the URL
VITE_GOOGLE_FORM_ID=your_google_form_id_here

# Character Data API (Development Only)
# Used by npm run scripts:fetch-characters to download character list
# This is read-only, not used in production
VITE_API_CHARACTER_LIST=https://api.lunaris.moe/data/6.4.54/charlist.json

# Character Avatar API (Development Only)
# Used by npm run scripts:fetch-characters to download character avatars
VITE_API_AVATAR_BASE=https://api.lunaris.moe/data/assets/avataricon/

# Optional: Enable debugging
# Set to 'true' to enable verbose logging in development
VITE_DEBUG=false

# Build configuration (auto-detected, usually no need to change)
NODE_ENV=development
